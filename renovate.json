{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "prHourlyLimit": 2,
  "prConcurrentLimit": 5,
  "packageRules": [
    {
      "matchPackageNames": [
        "babel-eslint",
        "rollup-plugin-babel",
        "rollup-plugin-node-resolve"
      ],
      "groupName": "legacy package replacements"
    },
    {
      "matchPackagePatterns": ["^@material/"],
      "groupName": "material components web"
    },
    {
      "matchPackageNames": ["gulp", "gulp-sass", "sass", "gulp-autoprefixer"],
      "groupName": "gulp and sass tooling"
    },
    {
      "matchPackageNames": ["rollup", "@rollup/plugin-babel", "@rollup/plugin-node-resolve", "@rollup/plugin-commonjs"],
      "groupName": "rollup tooling"
    }
  ]
}
